# Tier-2 RAG (grounded, cited answers). Without this key the site still works —
# it just falls back to suggestions instead of generating answers.
#
# 1. Get a free key: https://console.groq.com  (open Llama models, generous free tier)
# 2. Local dev: copy this file to .env.local and paste your key below.
# 3. Production: add GROQ_API_KEY in Vercel → Project → Settings → Environment Variables.
GROQ_API_KEY=

# Optional: override the model. Verify current model ids on the Groq console.
# GROQ_MODEL=llama-3.3-70b-versatile
